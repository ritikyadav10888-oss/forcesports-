# ============================================================
# Force Sports & Wears India — Environment Variables
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to Git.
# ============================================================

# ---  Firebase (Required)  ---
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id

# --- Resend Email API (Required for inquiry email notifications) ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# --- API Base URL (for internal API calls) ---
# Local dev:
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
# Production (Firebase App Hosting):
# NEXT_PUBLIC_SITE_URL=https://your-app-hosting-url.hosted.app
# NEXT_PUBLIC_API_BASE_URL=https://your-app-hosting-url.hosted.app
