{
  "redirects": [
    { "source": "/contact", "destination": "/inquiry", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(assets|3d design|Bags|T-shirts|caps|jabraat|shatak|uniforms)/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*).(png|jpg|jpeg|gif|svg|webp|avif|ico|woff|woff2|ttf|otf)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
